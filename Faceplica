# Makefile pro portrait — C99, nullae dependentiae praeter libm

CC      ?= cc
CFLAGS  ?= -std=c99 -O2 -Wall -Wextra -Wpedantic -Wno-unused-parameter \
           -Wno-unused-function -Iinclude -Isrc -D_DEFAULT_SOURCE
LDFLAGS ?=
LDLIBS  ?= -lm

SRC := \
  sors.c \
  tabula.c \
  sdf.c \
  tumultus.c \
  color.c \
  exitus.c \
  facies.c \
  expressio.c \
  archetypum.c \
  lineamenta.c \
  coma.c \
  cutis.c \
  modus.c \
  effectus.c \
  vestis.c \
  ornamenta.c \
  imago.c

OBJ := $(SRC:.c=.o)
BIN := portrait
MAT := matricula

.PHONY: all clean exempla

all: portrait $(MAT)

portrait: portrait.c $(OBJ)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $^ $(LDLIBS)

matricula: matricula.c $(OBJ)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $^ $(LDLIBS)

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

clean:
	rm -f $(OBJ) portrait matricula portrait.o matricula.o
	rm -rf exempla_out

# Bibliotheca exemplorum — varia semina, archetypa, gentes, modi
exempla: portrait
	mkdir -p exempla_out
	./portrait -s 1  -a lar      -g humana  -m cartoon       -o exempla_out/lar.ppm
	./portrait -s 2  -a manes    -g humana  -m atramentum    -o exempla_out/manes.ppm
	./portrait -s 3  -a lemur    -g gigas   -m cartoon       -o exempla_out/lemur_gigas.ppm
	./portrait -s 4  -a ianus    -g nympha  -m anime         -o exempla_out/ianus_nympha.ppm
	./portrait -s 5  -a augur    -g humana  -m pictum        -o exempla_out/augur.ppm
	./portrait -s 6  -a quirinus -g nanus   -m cartoon       -o exempla_out/quirinus.ppm
	./portrait -s 7  -a carna    -g humana  -m niger         -o exempla_out/carna.ppm
	./portrait -s 8  -a genius   -g penates -m cartoon       -o exempla_out/genius.ppm
	./portrait -s 9  -a flamen   -g humana  -m ludicrum_viii -o exempla_out/flamen.ppm
	./portrait -s 10 -a faunus   -g furia   -m cartoon       -o exempla_out/faunus_furia.ppm
	./portrait -s 11 -a lemur    -g larva   -m atramentum    -o exempla_out/lemur_larva.ppm
	./portrait -s 12 -a ianus    -g satyrus -m anime         -o exempla_out/ianus_satyrus.ppm
	@echo "Exempla scripta in exempla_out/"
